# MongoDB Atlas Configuration Example
# Copy your actual connection string from MongoDB Atlas

PORT=3001
NODE_ENV=development

# MongoDB Atlas Connection String
# Replace the following with YOUR actual connection string from Atlas:
# 1. Go to MongoDB Atlas Dashboard
# 2. Click "Connect" on your cluster
# 3. Choose "Connect your application"
# 4. Copy the connection string
# 5. Replace <password> with your actual password
# 6. Add database name "splitapp" before the "?"

MONGODB_URI=mongodb+srv://splitapp_user:YOUR_PASSWORD_HERE@cluster0.xxxxx.mongodb.net/splitapp?retryWrites=true&w=majority

# Example (DO NOT USE - this is just an example format):
# MONGODB_URI=mongodb+srv://myuser:MyPassword123@cluster0.abc123.mongodb.net/splitapp?retryWrites=true&w=majority

JWT_SECRET=splitapp-secret-key-2026-secure-token-12345
ACCESS_TOKEN_SECRET=splitapp-secret-key-2026-secure-token-12345
